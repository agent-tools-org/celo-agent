# Celo Payment Agent Configuration

# Network: "mainnet" or "testnet" (alfajores)
CELO_NETWORK=testnet

# Private key for the agent wallet (without 0x prefix)
PRIVATE_KEY=your_private_key_here

# Comma-separated addresses to monitor
MONITOR_ADDRESSES=0xYourAddress1,0xYourAddress2

# Monitoring interval in seconds (default: 30)
MONITOR_INTERVAL=30
