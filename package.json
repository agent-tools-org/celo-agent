{
  "name": "celo-payment-agent",
  "version": "1.0.0",
  "description": "AI-powered payment agent on Celo — sub-cent fees for frequent automated payments",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "demo": "ts-node --compiler-options '{\"module\":\"commonjs\",\"target\":\"ES2022\",\"esModuleInterop\":true,\"skipLibCheck\":true}' scripts/demo.ts",
    "compile": "ts-node src/compile.ts",
    "test": "vitest run"
  },
  "keywords": [
    "celo",
    "agent",
    "payments",
    "stablecoin",
    "viem"
  ],
  "license": "MIT",
  "dependencies": {
    "solc": "^0.8.24",
    "viem": "^2.21.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.0",
    "vitest": "^4.1.0"
  }
}
